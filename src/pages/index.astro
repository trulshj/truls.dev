---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import GardenCard from "../components/GardenCard.astro";

const recentItems = (await getCollection("garden"))
    .filter((x) => !x.data.isDraft)
    .sort(
        (a, b) =>
            (b.data.pubDate as Date).valueOf() -
            (a.data.pubDate as Date).valueOf(),
    )
    .slice(0, 6);

const talks = (await getCollection("talks")).sort(
    (a, b) => (b.data.date as Date).valueOf() - (a.data.date as Date).valueOf(),
);

const talkEntries = await Promise.all(
    talks.map(async (talk) => ({
        ...talk,
        Content: (await render(talk)).Content,
    })),
);

const pageTitle = "Kaffekrus";
---

<BaseLayout pageTitle={pageTitle}>
    <section class="hero">
        <div class="reveal">
            <p class="hero-name">Kaffekrus</p>
            <p class="hero-tagline">
                Hei og velkommen! Dette er min lille krok av internett — et sted
                jeg samler ting jeg lager, skriver og tenker på. Stikk innom
                hagen for å se hva som gror.
            </p>
        </div>
    </section>

    <section class="section" id="garden">
        <div class="section-header reveal">
            <h2>Nylig i hagen</h2>
            <p class="muted">Det siste fra hagen — tekst, kunst, fortellinger og notater.</p>
        </div>
        {recentItems.length > 0 ? (
            <div class="garden-grid">
                {recentItems.map((item) => (
                    <div class="reveal">
                        <GardenCard
                            slug={item.id.replace(/\.mdx?$/, "")}
                            title={item.data.title}
                            excerpt={item.data.excerpt}
                            type={item.data.type}
                            lang={item.data.lang}
                            status={item.data.status}
                            pubDate={item.data.pubDate as Date}
                            tags={item.data.tags}
                            image={item.data.image}
                        />
                    </div>
                ))}
            </div>
        ) : (
            <div class="card reveal">
                <p>
                    Hagen er under anlegg. Kom gjerne tilbake snart, eller{" "}
                    <a class="inline-link" href="mailto:post@truls.dev">si hei på e-post</a>
                    om du er nysgjerrig.
                </p>
            </div>
        )}
        <div class="reveal">
            <a href="/garden" class="cta-link">Se hele hagen →</a>
        </div>
    </section>

    <section class="section" id="talks">
        <div class="section-header reveal">
            <h2>Talks & videoer</h2>
            <p class="muted">Foredrag og presentasjoner jeg har holdt — med lenker til opptak.</p>
        </div>
        <ul class="talks-list">
            {talkEntries.map((talk) => (
                <li class="talk-item reveal">
                    <h3>{talk.data.title}</h3>
                    <div class="muted">
                        <talk.Content />
                    </div>
                    <div class="talk-links">
                        {talk.data.links.map(
                            (link: { label: string; href: string }) => (
                                <a href={link.href} class="talk-link">{link.label}</a>
                            ),
                        )}
                    </div>
                </li>
            ))}
        </ul>
    </section>

    <section class="section" id="about-teaser">
        <div class="card reveal">
            <p class="lead" style="font-size: 1rem;">
                Utvikler, visualiseringsstudent, danser og periodevis
                korsstingsentusiast. Glad i aha-opplevelser og gode samtaler.
            </p>
            <a href="/about" class="cta-link">Les mer om meg →</a>
        </div>
    </section>
</BaseLayout>
