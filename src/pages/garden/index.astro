---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GardenCard from "../../components/GardenCard.astro";

const allItems = (await getCollection("garden"))
    .filter((x) => !x.data.isDraft)
    .sort(
        (a, b) =>
            (b.data.pubDate as Date).valueOf() -
            (a.data.pubDate as Date).valueOf(),
    );

const usedTypes = new Set(allItems.map((x) => x.data.type));
const usedLangs = new Set(allItems.map((x) => x.data.lang));

const pageTitle = "Hagen";
---

<BaseLayout pageTitle={pageTitle}>
    <div class="garden-top">
        <div class="section-header reveal">
            <h1 style="font-size: clamp(1.8rem, 5vw, 2.8rem);">Hagen</h1>
            <p class="lead">
                Et samlingspunkt for det jeg lager og tenker på. Tekst, kunst, fortellinger og notater — noen ferske, noen under utvikling, noen modne.
            </p>
        </div>

        <div class="filter-bar reveal" aria-label="Filtrer innhold">
        <div class="filter-group">
            <button class="filter-btn active" data-filter-type="all" aria-pressed="true"><span class="btn-text">Alle</span><span class="btn-ja">すべて</span></button>
            {usedTypes.has("writing") && <button class="filter-btn" data-filter-type="writing" aria-pressed="false"><span class="btn-text">Tekst</span><span class="btn-ja">文章</span></button>}
            {usedTypes.has("art")     && <button class="filter-btn" data-filter-type="art"     aria-pressed="false"><span class="btn-text">Kunst</span><span class="btn-ja">芸術</span></button>}
            {usedTypes.has("story")   && <button class="filter-btn" data-filter-type="story"   aria-pressed="false"><span class="btn-text">Fortelling</span><span class="btn-ja">物語</span></button>}
            {usedTypes.has("note")    && <button class="filter-btn" data-filter-type="note"    aria-pressed="false"><span class="btn-text">Notat</span><span class="btn-ja">メモ</span></button>}
            {usedTypes.has("visualization") && <button class="filter-btn" data-filter-type="visualization" aria-pressed="false"><span class="btn-text">Visualisering</span><span class="btn-ja">可視化</span></button>}
        </div>
        {(usedLangs.size > 1) && (
            <div class="filter-group">
                <button class="filter-btn active" data-filter-lang="all" aria-pressed="true"><span class="btn-text">Alle språk</span><span class="btn-ja">すべて</span></button>
                {usedLangs.has("no") && <button class="filter-btn" data-filter-lang="no" aria-pressed="false"><span class="btn-text">NO</span><span class="btn-ja">ノルウェー語</span></button>}
                {usedLangs.has("en") && <button class="filter-btn" data-filter-lang="en" aria-pressed="false"><span class="btn-text">EN</span><span class="btn-ja">英語</span></button>}
                {usedLangs.has("ja") && <button class="filter-btn" data-filter-lang="ja" aria-pressed="false"><span class="btn-text">JA</span><span class="btn-ja">日本語</span></button>}
            </div>
        )}
    </div>
    </div>

    <div class="garden-grid" id="garden-grid">
        {allItems.map((item) => (
            <GardenCard
                slug={item.id.replace(/\.mdx?$/, "")}
                title={item.data.title}
                excerpt={item.data.excerpt}
                type={item.data.type}
                lang={item.data.lang}
                status={item.data.status}
                pubDate={item.data.pubDate as Date}
                tags={item.data.tags}
                image={item.data.image}
            />
        ))}
        {allItems.length === 0 && (
            <div class="card reveal" style="grid-column: 1 / -1;">
                <p>Hagen er under anlegg. Snart vokser det noe her.</p>
            </div>
        )}
    </div>

    <p class="no-results" id="no-results" style="display:none; color: var(--muted); font-family: var(--font-heading); font-size: 0.9rem;">
        Ingen innhold matcher filteret.
    </p>
</BaseLayout>

<script>
    function initFilters() {
        const typeButtons = document.querySelectorAll<HTMLButtonElement>("[data-filter-type]");
        const langButtons = document.querySelectorAll<HTMLButtonElement>("[data-filter-lang]");
        const cards = document.querySelectorAll<HTMLElement>(".garden-card");
        const noResults = document.getElementById("no-results");

        let activeType = "all";
        let activeLang = "all";

        function applyFilters() {
            let visible = 0;
            cards.forEach((card) => {
                const matchType = activeType === "all" || card.dataset.type === activeType;
                const matchLang = activeLang === "all" || card.dataset.lang === activeLang;
                const show = matchType && matchLang;
                card.classList.toggle("garden-card--hidden", !show);
                if (show) visible++;
            });
            if (noResults) {
                noResults.style.display = visible === 0 ? "block" : "none";
            }
        }

        typeButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                activeType = btn.dataset.filterType ?? "all";
                typeButtons.forEach((b) => {
                    b.classList.toggle("active", b === btn);
                    b.setAttribute("aria-pressed", b === btn ? "true" : "false");
                });
                applyFilters();
            });
        });

        langButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                activeLang = btn.dataset.filterLang ?? "all";
                langButtons.forEach((b) => {
                    b.classList.toggle("active", b === btn);
                    b.setAttribute("aria-pressed", b === btn ? "true" : "false");
                });
                applyFilters();
            });
        });
    }

    initFilters();
    document.addEventListener("astro:after-swap", initFilters);
</script>
