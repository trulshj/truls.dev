---
import { getCollection, render } from "astro:content";
import GardenItemLayout from "../../layouts/GardenItemLayout.astro";

export async function getStaticPaths() {
    const entries = await getCollection("garden");
    return entries
        .filter((x) => !x.data.isDraft)
        .map((entry) => ({
            params: { slug: entry.id.replace(/\.mdx?$/, "") },
            props: { entry },
        }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<GardenItemLayout frontmatter={entry.data}>
    <Content />
</GardenItemLayout>
