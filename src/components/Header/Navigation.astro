---
const currentPath = Astro.url.pathname;
const active = (path: string) => {
    if (path === "/") return currentPath === "/" ? "active" : "";
    return currentPath === path || currentPath.startsWith(`${path}/`) ? "active" : "";
};
---

<div id="primary-nav" class="nav-links">
    <a href="/" class={active("/")}>
        <span class="nav-text">hjem</span>
        <span class="nav-ja">ホーム</span>
    </a>
    <a href="/garden" class={active("/garden")}>
        <span class="nav-text">hagen</span>
        <span class="nav-ja">庭</span>
    </a>
    <a href="/about" class={active("/about")}>
        <span class="nav-text">om</span>
        <span class="nav-ja">概要</span>
    </a>
</div>

<style>
    .nav-links {
        display: none;
        position: absolute;
        right: 1rem;
        top: calc(100% + 0.5rem);
        flex-direction: column;
        gap: 0.2rem;
        padding: 0.6rem;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-hover);
        min-width: 160px;
        z-index: 10;
    }

    .nav-links.is-open {
        display: flex;
    }

    .nav-links a {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: bold;
        letter-spacing: 0.02em;
        color: var(--muted);
        text-decoration: none;
        padding: 0.5rem 0.7rem;
        border-radius: 2px;
        position: relative;
        transition: color var(--transition-speed) ease, background var(--transition-speed) ease;
    }

    .nav-text,
    .nav-ja {
        transition: opacity 0.15s ease;
    }

    .nav-ja {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        font-family: "Noto Sans JP", sans-serif;
        font-weight: 400;
        letter-spacing: 0;
    }

    .nav-links a:hover .nav-text,
    .nav-links a:focus-visible .nav-text {
        opacity: 0;
    }

    .nav-links a:hover .nav-ja,
    .nav-links a:focus-visible .nav-ja {
        opacity: 1;
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
        color: var(--ink);
        background: var(--bg);
        text-decoration: none;
    }

    .nav-links a.active {
        color: var(--ink);
        border-bottom: 2px solid var(--leaf);
    }

    @media (min-width: 760px) {
        .nav-links {
            display: flex;
            flex-direction: row;
            position: static;
            padding: 0;
            background: none;
            border: none;
            box-shadow: none;
            min-width: auto;
            gap: 0.25rem;
            margin-left: auto;
        }

        .nav-links a {
            padding: 0.3rem 0.6rem;
        }

        .nav-links a.active {
            border-bottom: 2px solid var(--leaf);
        }
    }
</style>
